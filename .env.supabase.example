APP_NAME=Wargify
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DB_SSLMODE=disable

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLIC_URL="${APP_URL}/api/v1/storage"
# Isi dari output: npm run supabase:status
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROFILE_BUCKET=profile-pictures
SUPABASE_ACTIVITY_BUCKET=activity-photos
SUPABASE_ANNOUNCEMENT_BUCKET=announcement-banners
SUPABASE_GALLERY_BUCKET=gallery-images
SUPABASE_REPORT_BUCKET=facility-reports
SUPABASE_TREASURY_BUCKET=treasury-receipts

FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log
MAIL_MAILER=log

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

VITE_APP_NAME="${APP_NAME}"
