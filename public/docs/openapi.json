{
  "openapi": "3.0.3",
  "info": {
    "title": "Wargify API",
    "description": "Dokumentasi endpoint API Wargify.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/api",
      "description": "Current application API"
    }
  ],
  "tags": [
    {
      "name": "Authentication"
    },
    {
      "name": "Profile"
    },
    {
      "name": "Users"
    },
    {
      "name": "Families"
    },
    {
      "name": "Ronda"
    }
  ],
  "paths": {
    "/v1/login": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Login user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              },
              "example": {
                "username": "superadmin",
                "password": "admin123"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login berhasil",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          }
        }
      }
    },
    "/v1/logout": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Logout user",
        "security": [
          {
            "sanctum": []
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/SuccessMessage"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          }
        }
      }
    },
    "/v1/me": {
      "get": {
        "tags": ["Profile"],
        "summary": "Ambil data user yang sedang login",
        "security": [
          {
            "sanctum": []
          }
        ],
        "responses": {
          "200": {
            "description": "Data user aktif",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/SuccessEnvelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/User"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          }
        }
      }
    },
    "/v1/users": {
      "get": {
        "tags": ["Users"],
        "summary": "Daftar user",
        "security": [
          {
            "sanctum": []
          }
        ],
        "responses": {
          "200": {
            "description": "Daftar user",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/SuccessEnvelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/User"
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          }
        }
      },
      "post": {
        "tags": ["Users"],
        "summary": "Tambah user",
        "security": [
          {
            "sanctum": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserStoreRequest"
              },
              "example": {
                "family_id": "9b3c0f2a-2a7d-4d47-a4b0-5f39c7436d88",
                "username": "warga01",
                "full_name": "Warga Satu",
                "password": "password",
                "role": "WARGA",
                "phone_number": "081234567890"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User berhasil dibuat",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/SuccessEnvelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/User"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          }
        }
      }
    },
    "/v1/users/{user}": {
      "get": {
        "tags": ["Users"],
        "summary": "Detail user",
        "security": [
          {
            "sanctum": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/UserId"
          }
        ],
        "responses": {
          "200": {
            "description": "Detail user",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/SuccessEnvelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/User"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "put": {
        "tags": ["Users"],
        "summary": "Update user",
        "security": [
          {
            "sanctum": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/UserId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User berhasil diupdate",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/SuccessEnvelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/User"
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          }
        }
      },
      "patch": {
        "tags": ["Users"],
        "summary": "Update sebagian data user",
        "security": [
          {
            "sanctum": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/UserId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User berhasil diupdate"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          }
        }
      },
      "delete": {
        "tags": ["Users"],
        "summary": "Hapus user",
        "security": [
          {
            "sanctum": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/UserId"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/SuccessMessage"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/v1/families": {
      "get": {
        "tags": ["Families"],
        "summary": "Daftar keluarga",
        "security": [
          {
            "sanctum": []
          }
        ],
        "responses": {
          "200": {
            "description": "Daftar keluarga",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Family"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          }
        }
      },
      "post": {
        "tags": ["Families"],
        "summary": "Tambah keluarga",
        "security": [
          {
            "sanctum": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FamilyStoreRequest"
              },
              "example": {
                "household_id": "8f6da3e4-6df9-4c97-8be3-c8f6f987d321",
                "qr_code_data": "FAMILY-001"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Keluarga berhasil dibuat"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          }
        }
      }
    },
    "/v1/families/{family}": {
      "get": {
        "tags": ["Families"],
        "summary": "Detail keluarga",
        "security": [
          {
            "sanctum": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/FamilyId"
          }
        ],
        "responses": {
          "200": {
            "description": "Detail keluarga"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "tags": ["Families"],
        "summary": "Hapus keluarga",
        "security": [
          {
            "sanctum": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/FamilyId"
          }
        ],
        "responses": {
          "200": {
            "$ref": "#/components/responses/SuccessMessage"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/v1/ronda/schedules": {
      "get": {
        "tags": ["Ronda"],
        "summary": "Jadwal ronda hari ini",
        "security": [
          {
            "sanctum": []
          }
        ],
        "responses": {
          "200": {
            "description": "Daftar jadwal ronda hari ini",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/SuccessEnvelope"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/RondaSchedule"
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          }
        }
      }
    },
    "/v1/ronda/attendance": {
      "post": {
        "tags": ["Ronda"],
        "summary": "Absensi ronda",
        "security": [
          {
            "sanctum": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RondaAttendanceRequest"
              },
              "example": {
                "schedule_id": "2f1c0eaa-7c33-420a-98a5-eab6ab337c44"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Absensi berhasil"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          },
          "500": {
            "$ref": "#/components/responses/ServerError"
          }
        }
      }
    },
    "/v1/ronda/groups": {
      "post": {
        "tags": ["Ronda"],
        "summary": "Buat grup ronda",
        "security": [
          {
            "sanctum": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RondaGroupStoreRequest"
              },
              "example": {
                "name": "Grup Ronda A"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Grup ronda berhasil dibuat"
          },
          "401": {
            "$ref": "#/components/responses/Unauthenticated"
          },
          "422": {
            "$ref": "#/components/responses/ValidationError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "sanctum": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "Sanctum token",
        "description": "Gunakan token dari endpoint login sebagai Bearer token."
      }
    },
    "parameters": {
      "UserId": {
        "name": "user",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "FamilyId": {
        "name": "family",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "schemas": {
      "SuccessEnvelope": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string",
            "format": "password"
          }
        }
      },
      "LoginResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SuccessEnvelope"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "user": {
                    "$ref": "#/components/schemas/User"
                  },
                  "token": {
                    "type": "string"
                  }
                }
              }
            }
          }
        ]
      },
      "User": {
        "type": "object",
        "properties": {
          "user_id": {
            "type": "string",
            "format": "uuid"
          },
          "family_id": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "username": {
            "type": "string"
          },
          "full_name": {
            "type": "string"
          },
          "phone_number": {
            "type": "string",
            "nullable": true
          },
          "role": {
            "type": "string",
            "enum": ["SUPERADMIN", "KETUA_RT", "BENDAHARA", "WARGA"]
          },
          "fcm_token": {
            "type": "string",
            "nullable": true
          },
          "profile_picture_url": {
            "type": "string",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "UserStoreRequest": {
        "type": "object",
        "required": ["family_id", "username", "full_name", "password", "role"],
        "properties": {
          "family_id": {
            "type": "string",
            "format": "uuid"
          },
          "username": {
            "type": "string"
          },
          "full_name": {
            "type": "string"
          },
          "password": {
            "type": "string",
            "format": "password",
            "minLength": 6
          },
          "role": {
            "type": "string",
            "enum": ["KETUA_RT", "WARGA"]
          },
          "phone_number": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "UserUpdateRequest": {
        "type": "object",
        "properties": {
          "family_id": {
            "type": "string",
            "format": "uuid"
          },
          "username": {
            "type": "string"
          },
          "full_name": {
            "type": "string"
          },
          "password": {
            "type": "string",
            "format": "password"
          },
          "phone_number": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "Family": {
        "type": "object",
        "properties": {
          "family_id": {
            "type": "string",
            "format": "uuid"
          },
          "household_id": {
            "type": "string",
            "format": "uuid"
          },
          "head_of_family_id": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "qr_code_data": {
            "type": "string",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "FamilyStoreRequest": {
        "type": "object",
        "required": ["household_id"],
        "properties": {
          "household_id": {
            "type": "string",
            "format": "uuid"
          },
          "qr_code_data": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "RondaSchedule": {
        "type": "object",
        "properties": {
          "schedule_id": {
            "type": "string",
            "format": "uuid"
          },
          "group_id": {
            "type": "string",
            "format": "uuid"
          },
          "coordinator_id": {
            "type": "string",
            "format": "uuid"
          },
          "schedule_date": {
            "type": "string",
            "format": "date"
          },
          "shift_start": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "shift_end": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "status": {
            "type": "string",
            "enum": ["SCHEDULED", "ONGOING", "COMPLETED", "MISSED"]
          }
        }
      },
      "RondaAttendanceRequest": {
        "type": "object",
        "required": ["schedule_id"],
        "properties": {
          "schedule_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "RondaGroupStoreRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "SuccessMessage": {
        "description": "Operasi berhasil",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/SuccessEnvelope"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Username atau password salah",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthenticated": {
        "description": "Token tidak valid atau belum dikirim"
      },
      "NotFound": {
        "description": "Data tidak ditemukan"
      },
      "ValidationError": {
        "description": "Validasi gagal"
      },
      "ServerError": {
        "description": "Terjadi kesalahan server"
      }
    }
  }
}
